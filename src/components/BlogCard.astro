---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  dateFormatter?: (date: Date) => string;
  articleClass?: string;
  wrapperClass?: string;
  imageClass?: string;
  contentClass?: string;
  metaClass?: string;
  categoryClass?: string;
  dateClass?: string;
  titleClass?: string;
  excerptClass?: string;
  linkClass?: string;
  readMoreLabel?: string;
  lazy?: boolean;
}

const {
  post,
  dateFormatter = (date: Date) => date.toLocaleDateString("ru-RU"),
  articleClass = "",
  wrapperClass = "",
  imageClass = "",
  contentClass = "",
  metaClass = "",
  categoryClass = "",
  dateClass = "",
  titleClass = "",
  excerptClass = "",
  linkClass = "",
  readMoreLabel = "Читать далее",
  lazy = true,
} = Astro.props;
---

<article class={articleClass}>
  <div class={wrapperClass}>
    <img
      src={post.data.cover}
      alt={post.data.coverAlt ?? post.data.title}
      class={imageClass}
      loading={lazy ? "lazy" : "eager"}
    />
  </div>
  <div class={contentClass}>
    <div class={metaClass}>
      <span class={categoryClass}>{post.data.category}</span>
      <span class={dateClass}>{dateFormatter(post.data.date)}</span>
    </div>
    <h3 class={titleClass} style="margin: 14px 0; font-size: 1.45rem; line-height: 1.3;">{post.data.title}</h3>
    <p class={excerptClass}>{post.data.excerpt}</p>
    <a href={`/blog/${post.slug}/`} class={linkClass}>{readMoreLabel}</a>
  </div>
</article>
