---
import { contactChannels } from "../../data/site";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations("en");

const featuredWorks = [
  {
    title: "Riverside Residence",
    category: "Residential Interior",
    image: "/images/channel/living-light.jpg",
    href: "/en/portfolio/",
  },
  {
    title: "Aurum Lobby",
    category: "Development",
    image: "/images/channel/lobby-classic.jpg",
    href: "/en/portfolio/",
  },
  {
    title: "Frame Penthouse",
    category: "Premium Segment",
    image: "/images/channel/living-premium.jpg",
    href: "/en/portfolio/",
  },
];
---

<SiteLayout
  title="Contact | INTERIOR.360"
  description="Contact INTERIOR.360 studio for a 3D visualization project discussion."
  canonicalPath="/en/contact/"
  locale="en"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Contact</p>
      <h1>{t("contact.title")}</h1>
      <p class="lead">{t("contact.lead")}</p>
    </div>
    <button class="hero-panel brief-panel-trigger" type="button" data-brief-open aria-haspopup="dialog" aria-controls="project-brief-modal">
      <strong>{t("hero.brief")}</strong>
    </button>
  </section>

  <section class="grid grid-2">
    <div class="surface">
      <h2 style="font-size: 2rem; margin-bottom: 18px;">How to Reach Us</h2>
      <div class="grid" style="gap: 14px;">
        {contactChannels.map((channel) => (
          <a
            href={channel.href}
            class="surface"
            style="text-decoration: none; padding: 18px; box-shadow: none;"
          >
            <p class="kicker" style="margin-bottom: 8px;">{channel.label}</p>
            <strong style="font-size: 1.1rem;">{channel.value}</strong>
          </a>
        ))}
      </div>
    </div>
    <div class="surface">
      <h2 style="font-size: 2rem; margin-bottom: 18px;">See What We Do</h2>
      <div class="contact-portfolio">
        {featuredWorks.map((work) => (
          <a href={work.href} class="contact-portfolio-card">
            <div class="contact-portfolio-img">
              <img src={work.image} alt={work.title} loading="lazy" />
            </div>
            <div class="contact-portfolio-info">
              <span class="contact-portfolio-category">{work.category}</span>
              <strong>{work.title}</strong>
            </div>
          </a>
        ))}
      </div>
      <p class="muted" style="margin-top: 18px;">
        Want something similar? Tell us about your project — and we'll propose a solution.
      </p>
    </div>
  </section>

  <style>
    .contact-portfolio {
      display: flex;
      flex-direction: row;
      gap: 12px;
      flex: 1;
      align-self: stretch;
    }

    .contact-portfolio-card {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
      padding: 10px;
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      transition: background 0.3s ease, transform 0.3s ease;
      border: 1px solid transparent;
      flex: 1;
      min-width: 0;
      height: 100%;
    }

    .contact-portfolio-card:hover {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(92, 141, 255, 0.2);
      transform: translateX(6px);
    }

    .contact-portfolio-img {
      width: 100%;
      flex: 1;
      min-height: 120px;
      border-radius: 10px;
      overflow: hidden;
      flex-shrink: 0;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .contact-portfolio-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease, filter 0.3s ease;
    }

    .contact-portfolio-card:hover .contact-portfolio-img img {
      transform: scale(1.12);
      filter: brightness(1.1) contrast(1.05);
    }

    .contact-portfolio-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .contact-portfolio-category {
      font-size: 0.75rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .contact-portfolio-info strong {
      font-size: 1rem;
      line-height: 1.3;
    }

    @media (max-width: 900px) {
      .contact-portfolio-card {
        padding: 8px;
      }

      .contact-portfolio {
        flex-direction: column;
      }

      .contact-portfolio-img {
        height: 140px;
      }
    }
  </style>
</SiteLayout>
