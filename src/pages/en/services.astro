---
import { servicesEn } from "../../data/site-en";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations("en");
---

<SiteLayout
  title="Services | INTERIOR.360"
  description="INTERIOR.360 services: interior 3D visualization, animation, design projects and presentation for private and commercial spaces."
  canonicalPath="/en/services/"
  locale="en"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Services</p>
      <h1>{t("services.title")}</h1>
      <p class="lead">
        {t("services.lead")}
      </p>
    </div>
    <button class="hero-panel brief-panel-trigger" type="button" data-brief-open aria-haspopup="dialog" aria-controls="project-brief-modal">
      <strong>{t("hero.brief")}</strong>
    </button>
  </section>

  <section class="section">
    <div class="grid grid-3">
      {servicesEn.map((service) => (
        <article class="surface service-accordion" data-accordion-item>
          <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
            <h2>{service.title}</h2>
          </button>
          <div class="service-preview">
            <p class="muted service-intro">{service.description}</p>
            <div class="service-media-slot service-media-slot-filled">
              {service.title === "Concept Style Creation" ? (
                <img
                  class="service-media-image"
                  src="/images/channel/collaje-mat3.jpg"
                  alt="Materials and textures collage for concept style"
                  loading="lazy"
                />
              ) : service.title === "Working Documentation" ? (
                <img
                  class="service-media-image service-media-image-workdoc"
                  src="/images/channel/workdoc.jpg"
                  alt="Working documentation and project drawings"
                  loading="lazy"
                />
              ) : service.title === "3D Visualization" ? (
                <img
                  class="service-media-image service-media-image-visual"
                  src="/images/channel/yslygi 3.jpg"
                  alt="3D interior visualization"
                  loading="lazy"
                />
              ) : service.title === "Project Cost by Stages" ? (
                <img
                  class="service-media-image service-media-image-budget"
                  src="/images/channel/album.jpg"
                  alt="Project cost by stages"
                  loading="lazy"
                />
              ) : service.title === "Developer Presentation" ? (
                <img
                  class="service-media-image service-media-image-developer"
                  src="/images/channel/yslygi 6.jpg"
                  alt="Developer presentation"
                  loading="lazy"
                />
              ) : service.title === "Panorama & Room Tour" ? (
                <video
                  class="service-media-image"
                  src="/images/channel/animation-walkthrough.mp4"
                  autoplay
                  loop
                  muted
                  playsinline
                  loading="lazy"
                ></video>
              ) : (
                <div class="service-media-placeholder" aria-hidden="true">
                  <span>Stage Preview</span>
                </div>
              )}
            </div>
            <div class="service-actions">
              <a class="button-secondary" href={service.ctaHref}>
                {service.ctaLabel}
              </a>
              <a class="button-secondary" href="/en/calculator/">Calculate cost</a>
            </div>
          </div>
          <div class="service-content">
            <ul class="list">
              {service.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
      <article class="surface service-accordion" data-accordion-item id="calculate">
        <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
          <h2>Implementation budget structure and procurement guide</h2>
        </button>
        <div class="service-preview">
          <p class="muted service-intro">
            Helps you understand the cost structure, procurement composition and key positions of materials, furniture and equipment in advance.
          </p>
          <div class="service-media-slot service-media-slot-filled">
            <img
              class="service-media-image service-media-image-procurement"
              src="/images/channel/yslygi 4.jpg"
              alt="Implementation budget structure and procurement guide"
              loading="lazy"
            />
          </div>
          <div class="service-actions">
            <a class="button-secondary" href="/en/calculator/">Calculate cost</a>
          </div>
        </div>
        <div class="service-content">
          <p class="kicker">Budget and procurement</p>
          <ul class="list">
            <li>Estimated budget range for the project</li>
            <li>Separation into rough and finish works</li>
            <li>Cost estimation for materials, furniture, lighting and plumbing</li>
            <li>Understanding how budget depends on area and scope of work</li>
            <li>Finishing materials by rooms</li>
            <li>Lighting equipment and lighting scenarios</li>
            <li>Plumbing, doors and built-in elements</li>
            <li>Furniture, decor and key procurement positions</li>
          </ul>
        </div>
      </article>
      <article class="surface service-accordion" data-accordion-item>
        <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
          <h2>On-site works</h2>
        </button>
        <div class="service-preview">
          <p class="muted service-intro">
            Precise coordination of all implementation stages, control of deadlines and budget. Additionally allows synchronizing the work of contractors and suppliers, optimizing material logistics and accounting for technological dependencies in advance.
          </p>
          <div class="service-media-slot service-media-slot-filled">
            <img
              class="service-media-image service-media-image-sitework"
              src="/images/channel/yslygi 9.jpg"
              alt="On-site works and implementation stages"
              loading="lazy"
            />
          </div>
          <div class="service-actions">
            <a class="button-secondary" href="/en/calculator/">Calculate cost</a>
          </div>
        </div>
        <div class="service-content">
          <p class="kicker">Schedule</p>
          <ul class="list">
            <li>Site preparation and organization</li>
            <li>Demolition and rough works</li>
            <li>Engineering systems and installation</li>
            <li>Finish works, procurement and final stage</li>
          </ul>
        </div>
      </article>
    </div>
  </section>
</SiteLayout>

<style is:inline>
  .page-hero .eyebrow {
    color: #b8ff6a;
  }

  .grid.grid-3 {
    align-items: start;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .service-accordion {
    padding: 0;
    overflow: hidden;
    align-self: start;
  }

  .service-summary {
    width: 100%;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 24px;
    cursor: pointer;
    border: 0;
    background: transparent;
    color: inherit;
    text-align: left;
  }

  .service-summary h2 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.08;
    min-height: 2.6em;
    display: flex;
    align-items: flex-start;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .service-summary:hover h2 {
    color: #ffffff;
    text-shadow: 0 0 18px rgba(255, 255, 255, 0.22);
  }

  .service-content {
    display: none;
    gap: 0;
    padding: 0 24px 24px;
  }

  .service-accordion.is-open .service-content {
    display: grid;
  }

  .service-preview {
    display: grid;
    gap: 0;
    padding: 0 24px 24px;
    grid-template-rows: auto auto auto;
    align-content: start;
  }

  .service-media-slot {
    overflow: hidden;
    height: 200px;
    min-height: 200px;
    margin: 6px 0 14px;
    border-radius: 18px;
    border: 1px dashed rgba(92, 141, 255, 0.24);
    background: rgba(255, 255, 255, 0.02);
  }

  .service-media-slot-filled {
    border-style: solid;
    background: rgba(255, 255, 255, 0.03);
    margin-left: -24px;
    margin-right: -24px;
    width: calc(100% + 48px);
    border-radius: 0;
    margin-bottom: 10px;
  }

  .service-media-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at 20% 20%, rgba(92, 141, 255, 0.18), transparent 32%),
      radial-gradient(circle at 78% 70%, rgba(184, 255, 106, 0.14), transparent 28%);
  }

  .service-media-placeholder span {
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .service-media-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center calc(50% - 100px);
  }

  .service-media-image-workdoc {
    object-position: center calc(50% + 30px);
  }

  .service-media-image-visual {
    object-position: center calc(50% - 15px);
  }

  .service-media-image-sitework {
    object-position: center calc(50% + 100px);
  }

  .service-media-image-developer {
    object-position: center calc(50% + 190px);
  }

  .service-media-image-budget {
    object-position: center calc(50% + 5px);
  }

  .service-media-image-procurement {
    width: calc(100% + 100px);
    max-width: none;
    transform: translateX(-100px);
  }

  .service-content .kicker {
    margin-bottom: 14px;
  }

  .service-preview .service-intro,
  .service-content .service-intro {
    color: #5c8dff;
    margin-top: -6px;
    margin-bottom: 12px;
    font-size: 0.88rem;
    line-height: 1.5;
    min-height: 4.5em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }

  .service-actions .button-secondary {
    min-height: 40px;
    padding: 0 14px;
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    white-space: normal;
    text-align: center;
  }

  .service-actions .button-secondary:only-child {
    grid-column: 1 / -1;
  }

  .service-actions .button-secondary {
    color: #b8ff6a;
    border-color: #b8ff6a;
  }

  .service-actions .button-secondary[href="/en/portfolio/"] {
    color: #5c8dff;
    border-color: #5c8dff;
  }

  @media (max-width: 1200px) {
    .grid.grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .grid.grid-3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .grid.grid-3 {
      grid-template-columns: 1fr;
    }

    .page-hero {
      gap: 14px;
    }

    .service-summary {
      padding: 18px 18px 14px;
    }

    .service-summary h2 {
      font-size: 1rem;
      line-height: 1.08;
      min-height: 0;
    }

    .service-preview {
      padding: 0 18px 18px;
    }

    .service-preview .service-intro,
    .service-content .service-intro {
      margin-top: -2px;
      margin-bottom: 10px;
      font-size: 0.8rem;
      line-height: 1.46;
      min-height: 0;
    }

    .service-media-slot {
      height: 140px;
      min-height: 140px;
      margin: 2px 0 10px;
      border-radius: 14px;
    }

    .service-media-slot-filled {
      margin-left: -18px;
      margin-right: -18px;
      width: calc(100% + 36px);
      margin-bottom: 8px;
    }

    .service-actions {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .service-actions .button-secondary {
      width: 100%;
    }

    .service-content {
      padding: 0 18px 18px;
    }

    .service-content .list {
      margin-top: 10px;
      padding-left: 16px;
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .service-content .kicker {
      margin-bottom: 10px;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
    }

  }
</style>

<script is:inline>
  (() => {
    const initAccordions = () => {
      document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-accordion-trigger]");
        if (!trigger) return;

        const item = trigger.closest("[data-accordion-item]");
        if (!item) return;

        const accordionItems = document.querySelectorAll("[data-accordion-item]");
        const willOpen = !item.classList.contains("is-open");

        accordionItems.forEach((accordionItem) => {
          accordionItem.classList.remove("is-open");
          const accordionTrigger = accordionItem.querySelector("[data-accordion-trigger]");
          if (accordionTrigger) {
            accordionTrigger.setAttribute("aria-expanded", "false");
          }
        });

        if (willOpen) {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        () => {
          initAccordions();
        },
        { once: true }
      );
    } else {
      initAccordions();
    }
  })();
</script>
