---
import { services } from "../data/site";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Услуги | INTERIOR.360"
  description="Услуги студии INTERIOR.360: интерьерная 3D-визуализация, анимация, дизайн-проекты и подача для частных и коммерческих пространств."
  canonicalPath="/services/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Services</p>
      <h1>Услуги и процесс</h1>
      <p class="lead">
        Здесь можно посмотреть форматы работы, состав услуг и понять, как устроена подача проекта на разных стадиях.
      </p>
    </div>
    <button class="hero-panel brief-panel-trigger" type="button" data-brief-open aria-haspopup="dialog" aria-controls="project-brief-modal">
      <strong>Заполнить бриф проекта</strong>
    </button>
  </section>

  <div class="brief-modal" id="project-brief-modal" data-brief-modal hidden>
    <div class="brief-modal__backdrop" data-brief-close></div>
    <div class="brief-modal__dialog surface" role="dialog" aria-modal="true" aria-labelledby="brief-modal-title">
      <button class="brief-modal__close" type="button" data-brief-close aria-label="Закрыть">×</button>
      <div class="brief-modal__content">
        <p class="eyebrow">Brief</p>
        <h2 id="brief-modal-title">Заполнить бриф проекта</h2>
        <p class="lead">
          Коротко опишите задачу, формат проекта и ожидаемый результат, чтобы мы могли быстро собрать понятный сценарий работы.
        </p>
        <div class="brief-modal__grid">
          <label>
            <span>Имя / компания</span>
            <input type="text" placeholder="Как к вам обращаться?" />
          </label>
          <label>
            <span>Контакт</span>
            <input type="text" placeholder="Telegram, WhatsApp, email или телефон" />
          </label>
          <label>
            <span>Формат проекта</span>
            <input type="text" placeholder="Частный, B2B, девелопмент..." />
          </label>
          <label>
            <span>Площадь / масштаб</span>
            <input type="text" placeholder="м2, количество помещений или объектов" />
          </label>
          <label class="brief-modal__field-wide">
            <span>Задача проекта</span>
            <textarea rows="4" placeholder="Что нужно сделать, какой объём работ нужен и какой результат важен?"></textarea>
          </label>
          <label class="brief-modal__field-wide">
            <span>Сроки и комментарии</span>
            <textarea rows="4" placeholder="Укажите сроки, ожидания по подаче и важные нюансы проекта."></textarea>
          </label>
          <label class="brief-modal__field-wide brief-modal__upload">
            <span>Файлы проекта</span>
            <input type="file" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp,.zip,.rar,.dwg" />
            <small>Можно прикрепить референсы, планы, ТЗ, изображения и сопроводительные материалы.</small>
          </label>
        </div>
        <div class="brief-modal__actions">
          <a class="button-secondary" href="/contact/">Отправить запрос</a>
          <button class="button-secondary brief-modal__dismiss" type="button" data-brief-close>Закрыть</button>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="grid grid-3">
      {services.map((service) => (
        <article class="surface service-accordion" data-accordion-item>
          <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
            <h2>{service.title}</h2>
          </button>
          <div class="service-preview">
            <p class="muted service-intro">{service.description}</p>
            <div class="service-media-slot service-media-slot-filled">
              {service.title === "Создание концептуального стиля проекта" ? (
                <img
                  class="service-media-image"
                  src="/images/channel/collaje-mat3.jpg"
                  alt="Коллаж материалов и фактур для концептуального стиля проекта"
                  loading="lazy"
                />
              ) : service.title === "Рабочая документация" ? (
                <img
                  class="service-media-image service-media-image-workdoc"
                  src="/images/channel/workdoc.jpg"
                  alt="Рабочая документация и чертежи проекта"
                  loading="lazy"
                />
              ) : service.title === "3D Визуализация" ? (
                <img
                  class="service-media-image service-media-image-visual"
                  src="/images/channel/yslygi 3.jpg"
                  alt="3D визуализация интерьера"
                  loading="lazy"
                />
              ) : service.title === "Стоимость проектных работ по стадиям" ? (
                <img
                  class="service-media-image service-media-image-budget"
                  src="/images/channel/album.jpg"
                  alt="Стоимость проектных работ по стадиям"
                  loading="lazy"
                />
              ) : service.title === "Подача для девелоперов" ? (
                <img
                  class="service-media-image service-media-image-developer"
                  src="/images/channel/yslygi 6.jpg"
                  alt="Подача для девелоперов"
                  loading="lazy"
                />
              ) : (
                <div class="service-media-placeholder" aria-hidden="true">
                  <span>Stage Preview</span>
                </div>
              )}
            </div>
            <div class="service-actions">
              {service.ctaLabel && service.ctaHref ? (
                <a class="button-secondary" href={service.ctaHref}>
                  {service.ctaLabel}
                </a>
              ) : null}
              <a class="button-secondary" href="/calculator/">Рассчитать стоимость</a>
            </div>
          </div>
          <div class="service-content">
            <ul class="list">
              {service.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
      <article class="surface service-accordion" data-accordion-item id="calculate">
        <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
          <h2>Структура бюджета реализации и закупочный ориентир</h2>
        </button>
        <div class="service-preview">
          <p class="muted service-intro">
            Помогает заранее понять структуру расходов, состав комплектации и ключевые позиции материалов, мебели и оборудования.
          </p>
          <div class="service-media-slot service-media-slot-filled">
            <img
              class="service-media-image service-media-image-procurement"
              src="/images/channel/yslygi 4.jpg"
              alt="Структура бюджета реализации и закупочный ориентир"
              loading="lazy"
            />
          </div>
          <div class="service-actions">
            <a class="button-secondary" href="/calculator/">Рассчитать стоимость</a>
          </div>
        </div>
        <div class="service-content">
          <p class="kicker">Бюджет и комплектация</p>
          <ul class="list">
            <li>Предварительный диапазон бюджета по проекту</li>
            <li>Разделение на черновые и чистовые работы</li>
            <li>Оценка затрат на материалы, мебель, свет и сантехнику</li>
            <li>Понимание зависимости бюджета от площади и состава работ</li>
            <li>Отделочные материалы по помещениям</li>
            <li>Осветительное оборудование и сценарии света</li>
            <li>Сантехника, двери и встроенные элементы</li>
            <li>Мебель, декор и ключевые позиции комплектации</li>
          </ul>
        </div>
      </article>
      <article class="surface service-accordion" data-accordion-item>
        <button class="service-summary" type="button" data-accordion-trigger aria-expanded="false">
          <h2>Работы на объекте</h2>
        </button>
        <div class="service-preview">
          <p class="muted service-intro">
            Точная координация всех этапов реализации, контроль сроков и бюджета. Дополнительно позволяет синхронизировать работу подрядчиков и поставщиков, оптимизировать логистику материалов и заранее учитывать технологические зависимости.
          </p>
          <div class="service-media-slot service-media-slot-filled">
            <img
              class="service-media-image service-media-image-sitework"
              src="/images/channel/yslygi 9.jpg"
              alt="Работы на объекте и этапы реализации"
              loading="lazy"
            />
          </div>
          <div class="service-actions">
            <a class="button-secondary" href="/calculator/">Рассчитать стоимость</a>
          </div>
        </div>
        <div class="service-content">
          <p class="kicker">График</p>
          <ul class="list">
            <li>Подготовка и организация площадки</li>
            <li>Демонтажные и черновые работы</li>
            <li>Инженерные системы и монтаж</li>
            <li>Чистовая отделка, комплектация и финальный этап</li>
          </ul>
        </div>
      </article>
    </div>
  </section>
</SiteLayout>

<style is:inline>
  .page-hero .eyebrow {
    color: #b8ff6a;
  }

  .brief-panel-trigger {
    width: 100%;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .brief-panel-trigger:hover {
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.2);
  }

  .brief-panel-trigger strong {
    display: block;
    font-size: clamp(1.5rem, 2.4vw, 2.05rem);
    line-height: 1.08;
    text-align: left;
  }

  .brief-modal[hidden] {
    display: none;
  }

  .brief-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
  }

  .brief-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(4, 6, 12, 0.82);
    backdrop-filter: blur(14px);
  }

  .brief-modal__dialog {
    position: relative;
    z-index: 1;
    width: min(1120px, calc(100vw - 32px));
    max-height: calc(100vh - 32px);
    margin: 16px auto;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 28px;
  }

  .brief-modal__dialog {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .brief-modal__dialog::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .brief-modal__close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: #ffffff;
    font-size: 1.6rem;
    cursor: pointer;
  }

  .brief-modal__content h2 {
    margin-bottom: 10px;
  }

  .brief-modal__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 30px;
  }

  .brief-modal__grid label {
    display: grid;
    gap: 10px;
  }

  .brief-modal__grid span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brief-modal__grid input,
  .brief-modal__grid textarea {
    width: 100%;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: #ffffff;
    padding: 16px 18px;
    font: inherit;
    resize: vertical;
    overflow-x: hidden;
  }

  .brief-modal__field-wide {
    grid-column: 1 / -1;
  }

  .brief-modal__upload input[type="file"] {
    padding: 14px 16px;
    cursor: pointer;
  }

  .brief-modal__upload input[type="file"]::file-selector-button {
    margin-right: 14px;
    border: 1px solid rgba(184, 255, 106, 0.45);
    border-radius: 999px;
    background: rgba(184, 255, 106, 0.08);
    color: #b8ff6a;
    padding: 10px 16px;
    font: inherit;
    cursor: pointer;
  }

  .brief-modal__upload small {
    color: rgba(255, 255, 255, 0.54);
    line-height: 1.5;
  }

  .brief-modal__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .brief-modal__dismiss {
    background: transparent;
  }

  .grid.grid-3 {
    align-items: start;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .service-accordion {
    padding: 0;
    overflow: hidden;
    align-self: start;
  }

  .service-summary {
    width: 100%;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 24px;
    cursor: pointer;
    border: 0;
    background: transparent;
    color: inherit;
    text-align: left;
  }

  .service-summary h2 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.08;
    min-height: 2.6em;
    display: flex;
    align-items: flex-start;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .service-summary:hover h2 {
    color: #ffffff;
    text-shadow: 0 0 18px rgba(255, 255, 255, 0.22);
  }

  .service-content {
    display: none;
    gap: 0;
    padding: 0 24px 24px;
  }

  .service-accordion.is-open .service-content {
    display: grid;
  }

  .service-preview {
    display: grid;
    gap: 0;
    padding: 0 24px 24px;
    grid-template-rows: auto auto auto;
    align-content: start;
  }

  .service-media-slot {
    overflow: hidden;
    height: 200px;
    min-height: 200px;
    margin: 6px 0 14px;
    border-radius: 18px;
    border: 1px dashed rgba(92, 141, 255, 0.24);
    background: rgba(255, 255, 255, 0.02);
  }

  .service-media-slot-filled {
    border-style: solid;
    background: rgba(255, 255, 255, 0.03);
    margin-left: -24px;
    margin-right: -24px;
    width: calc(100% + 48px);
    border-radius: 0;
    margin-bottom: 10px;
  }

  .service-media-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at 20% 20%, rgba(92, 141, 255, 0.18), transparent 32%),
      radial-gradient(circle at 78% 70%, rgba(184, 255, 106, 0.14), transparent 28%);
  }

  .service-media-placeholder span {
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .service-media-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center calc(50% - 100px);
  }

  .service-media-image-workdoc {
    object-position: center calc(50% + 30px);
  }

  .service-media-image-visual {
    object-position: center calc(50% - 15px);
  }

  .service-media-image-sitework {
    object-position: center calc(50% + 100px);
  }

  .service-media-image-developer {
    object-position: center calc(50% + 190px);
  }

  .service-media-image-budget {
    object-position: center calc(50% + 5px);
  }

  .service-media-image-procurement {
    width: calc(100% + 100px);
    max-width: none;
    transform: translateX(-100px);
  }

  .service-content .kicker {
    margin-bottom: 14px;
  }

  .service-preview .service-intro,
  .service-content .service-intro {
    color: #5c8dff;
    margin-top: -6px;
    margin-bottom: 12px;
    font-size: 0.88rem;
    line-height: 1.5;
    min-height: 4.5em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: center;
    gap: 12px;
    margin-top: 12px;
  }

  .service-actions .button-secondary {
    min-height: 40px;
    padding: 0 14px;
    font-size: 0.64rem;
    letter-spacing: 0.08em;
    white-space: normal;
    text-align: center;
  }

  .service-actions .button-secondary:only-child {
    grid-column: 1 / -1;
  }

  .service-actions .button-secondary {
    color: #b8ff6a;
    border-color: #b8ff6a;
  }

  .service-actions .button-secondary[href="/portfolio/"] {
    color: #5c8dff;
    border-color: #5c8dff;
  }

  @media (max-width: 1200px) {
    .grid.grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .grid.grid-3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .grid.grid-3 {
      grid-template-columns: 1fr;
    }

    .page-hero {
      gap: 14px;
    }

    .brief-panel-trigger {
      min-height: 108px;
      padding: 18px;
    }

    .brief-panel-trigger strong {
      font-size: 1.28rem;
      line-height: 1.08;
    }

    .brief-modal__dialog {
      width: 100vw;
      max-height: 100vh;
      min-height: 100vh;
      margin: 0;
      border-radius: 0;
      padding: 56px 16px 22px;
    }

    .brief-modal__grid {
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 20px;
    }

    .brief-modal__content .lead {
      font-size: 0.92rem;
      line-height: 1.65;
    }

    .brief-modal__grid span {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
    }

    .brief-modal__grid input,
    .brief-modal__grid textarea {
      border-radius: 14px;
      padding: 14px 15px;
      font-size: 0.95rem;
    }

    .brief-modal__upload input[type="file"] {
      padding: 12px 14px;
    }

    .brief-modal__upload input[type="file"]::file-selector-button {
      display: block;
      width: 100%;
      margin: 0 0 10px;
      text-align: center;
    }

    .brief-modal__actions {
      gap: 10px;
      margin-top: 20px;
    }

    .brief-modal__actions .button-secondary {
      width: 100%;
    }

    .brief-modal__close {
      top: 12px;
      right: 12px;
      width: 40px;
      height: 40px;
    }

    .service-summary {
      padding: 18px 18px 14px;
    }

    .service-summary h2 {
      font-size: 1rem;
      line-height: 1.08;
      min-height: 0;
    }

    .service-preview {
      padding: 0 18px 18px;
    }

    .service-preview .service-intro,
    .service-content .service-intro {
      margin-top: -2px;
      margin-bottom: 10px;
      font-size: 0.8rem;
      line-height: 1.46;
      min-height: 0;
    }

    .service-media-slot {
      height: 140px;
      min-height: 140px;
      margin: 2px 0 10px;
      border-radius: 14px;
    }

    .service-media-slot-filled {
      margin-left: -18px;
      margin-right: -18px;
      width: calc(100% + 36px);
      margin-bottom: 8px;
    }

    .service-actions {
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .service-actions .button-secondary {
      width: 100%;
    }

    .service-content {
      padding: 0 18px 18px;
    }

    .service-content .list {
      margin-top: 10px;
      padding-left: 16px;
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .service-content .kicker {
      margin-bottom: 10px;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
    }

  }
</style>

<script is:inline>
  (() => {
    const initAccordions = () => {
      document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-accordion-trigger]");
        if (!trigger) return;

        const item = trigger.closest("[data-accordion-item]");
        if (!item) return;

        const accordionItems = document.querySelectorAll("[data-accordion-item]");
        const willOpen = !item.classList.contains("is-open");

        accordionItems.forEach((accordionItem) => {
          accordionItem.classList.remove("is-open");
          const accordionTrigger = accordionItem.querySelector("[data-accordion-trigger]");
          if (accordionTrigger) {
            accordionTrigger.setAttribute("aria-expanded", "false");
          }
        });

        if (willOpen) {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    };

    const initBriefModal = () => {
      const modal = document.querySelector("[data-brief-modal]");
      const openTrigger = document.querySelector("[data-brief-open]");
      if (!modal || !openTrigger) return;

      const closeModal = () => {
        modal.setAttribute("hidden", "");
        document.body.style.overflow = "";
      };

      const openModal = () => {
        modal.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
      };

      openTrigger.addEventListener("click", openModal);

      modal.addEventListener("click", (event) => {
        if (event.target.closest("[data-brief-close]")) {
          closeModal();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !modal.hasAttribute("hidden")) {
          closeModal();
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        () => {
          initAccordions();
          initBriefModal();
        },
        { once: true }
      );
    } else {
      initAccordions();
      initBriefModal();
    }
  })();
</script>
