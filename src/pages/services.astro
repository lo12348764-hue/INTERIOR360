---
import { processSteps, services } from "../data/site";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Услуги | INTERIOR.360"
  description="Услуги студии INTERIOR.360: интерьерная 3D-визуализация, анимация и материалы для девелоперов."
  canonicalPath="/services/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Services</p>
      <h1>Услуги и процесс</h1>
      <p class="lead">
        Вместо короткого блока на лендинге теперь есть полноценная страница с описанием форматов работы
        и этапов производства.
      </p>
    </div>
    <aside class="hero-panel">
      <p>Фокус</p>
      <strong>Качество подачи и понятный production</strong>
      <p>Подходит для</p>
      <strong>Дизайнеров, архитекторов, девелоперов</strong>
    </aside>
  </section>

  <section class="section">
    <div class="grid grid-3">
      {services.map((service) => (
        <article class="surface">
          <p class="kicker">Услуга</p>
          <h2 style="margin-top: 10px; font-size: 1.55rem;">{service.title}</h2>
          <p class="muted">{service.description}</p>
          <ul class="list">
            {service.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Как строим работу</h2>
    <p class="section-copy">
      Отдельная страница позволяет показать производственный процесс спокойно и последовательно, без перегруза на главной.
    </p>
    <div class="grid grid-2">
      {processSteps.map((step, index) => (
        <article class="surface">
          <p class="kicker">Этап {index + 1}</p>
          <h3 style="margin-top: 10px; font-size: 1.5rem;">{step.title}</h3>
          <p class="muted">{step.text}</p>
        </article>
      ))}
    </div>
  </section>
</SiteLayout>
