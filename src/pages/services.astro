---
import ServiceCalculator from "../components/ServiceCalculator.astro";
import { processSteps, services } from "../data/site";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Услуги | INTERIOR.360"
  description="Услуги студии INTERIOR.360: интерьерная 3D-визуализация, анимация, дизайн-проекты и инструменты оценки бюджета."
  canonicalPath="/services/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Services</p>
      <h1>Услуги и процесс</h1>
      <p class="lead">
        Здесь можно не только посмотреть форматы работы, но и сразу прикинуть бюджет проекта по ключевым параметрам:
        площади, сложности, составу проекта и уровню детализации.
      </p>
    </div>
    <aside class="hero-panel">
      <p>Фокус</p>
      <strong>Качество подачи, точная смета и понятный production</strong>
      <p>Подходит для</p>
      <strong>Дизайнеров, архитекторов, девелоперов и частных заказчиков</strong>
    </aside>
  </section>

  <section class="section">
    <div class="grid grid-3">
      {services.map((service) => (
        <article class="surface">
          <p class="kicker">Услуга</p>
          <h2 style="margin-top: 10px; font-size: 1.55rem;">{service.title}</h2>
          <p class="muted">{service.description}</p>
          <ul class="list">
            {service.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <ServiceCalculator />

  <section class="section">
    <h2 class="section-title">Как строим работу</h2>
    <p class="section-copy">
      Отдельная страница позволяет спокойно показать и процесс, и логику ценообразования: что входит в проект, где
      появляются дополнительные часы команды и почему разные объекты не могут стоить одинаково.
    </p>
    <div class="grid grid-2">
      {processSteps.map((step, index) => (
        <article class="surface">
          <p class="kicker">Этап {index + 1}</p>
          <h3 style="margin-top: 10px; font-size: 1.5rem;">{step.title}</h3>
          <p class="muted">{step.text}</p>
        </article>
      ))}
    </div>
  </section>
</SiteLayout>
