---
import { getCollection } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import { portfolioItems, services, studioStats } from "../data/site";
import SiteLayout from "../layouts/SiteLayout.astro";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
---

<SiteLayout
  title="INTERIOR.360 | 3D-визуализация интерьеров"
  description="Многостраничный сайт студии INTERIOR.360: портфолио, услуги, блог, информация о студии и контакты."
  canonicalPath="/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Interior Visualization Studio</p>
      <h1>СТУДИЯ ДИЗАЙНА ИНТЕРЬЕРА</h1>
      <div class="button-row">
        <a class="button" href="/portfolio/">Смотреть портфолио</a>
        <a class="button-secondary" href="/services/">Узнать об услугах</a>
      </div>
    </div>
    <aside class="hero-panel">
      <p>Структура</p>
      <strong>5 самостоятельных разделов</strong>
      <p>Подходит для</p>
      <strong>SEO, рекламы и удобной навигации</strong>
    </aside>
  </section>

  <section class="section">
    <h2 class="section-title">Дизайн жилых интерьеров</h2>
    <div class="projects-strip">
      {portfolioItems.slice(0, 10).map((item, index) => (
        <a class="card project-card project-card-link" href={`/portfolio/${item.slug}/`} aria-label={`Открыть проект ${item.title}`}>
          {index === 2 ? (
            <div class="media-frame media-frame-static" data-static-media>
              <div class="media-motion media-physics" style="--water-image: url('/images/channel/house-exterior.jpg');">
                <img class="media" src={item.image} alt={item.title} loading="lazy" />
                <div class="media-water-layer" aria-hidden="true"></div>
              </div>
            </div>
          ) : (
            <div class="media-frame">
              <div class="media-motion">
                <img class="media" src={item.image} alt={item.title} loading={index === 0 ? "eager" : "lazy"} />
              </div>
            </div>
          )}
          <div class="card-body">
            <p class="kicker">{item.category}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{item.title}</h3>
            <p class="muted" style="margin-bottom: 8px;">{item.location}</p>
            <p class="muted">{item.description}</p>
          </div>
        </a>
      ))}
    </div>
    <p class="section-title projects-caption">Таунхаусы дуплексы модульные дома</p>
    <div class="projects-strip secondary-projects-strip">
      {portfolioItems.slice(0, 10).map((item, index) => (
        <a class="card project-card project-card-link" href={`/portfolio/${item.slug}/`} aria-label={`Открыть проект ${item.title}`}>
          {index === 2 ? (
            <div class="media-frame media-frame-static" data-static-media>
              <div class="media-motion media-physics" style="--water-image: url('/images/channel/house-exterior.jpg');">
                <img class="media" src={item.image} alt={item.title} loading="lazy" />
                <div class="media-water-layer" aria-hidden="true"></div>
              </div>
            </div>
          ) : (
            <div class="media-frame">
              <div class="media-motion">
                <img class="media" src={item.image} alt={item.title} loading="lazy" />
              </div>
            </div>
          )}
          <div class="card-body">
            <p class="kicker">{item.category}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{item.title}</h3>
            <p class="muted" style="margin-bottom: 8px;">{item.location}</p>
            <p class="muted">{item.description}</p>
          </div>
        </a>
      ))}
    </div>
    <p class="section-title projects-caption">Бренд-пространства, b2b, выставочные стенды, Дизайн шоурумов, pop-up пространства</p>
    <div class="projects-strip secondary-projects-strip">
      {portfolioItems.slice(0, 10).map((item, index) => (
        <a class="card project-card project-card-link" href={`/portfolio/${item.slug}/`} aria-label={`Открыть проект ${item.title}`}>
          {index === 2 ? (
            <div class="media-frame media-frame-static" data-static-media>
              <div class="media-motion media-physics" style="--water-image: url('/images/channel/house-exterior.jpg');">
                <img class="media" src={item.image} alt={item.title} loading="lazy" />
                <div class="media-water-layer" aria-hidden="true"></div>
              </div>
            </div>
          ) : (
            <div class="media-frame">
              <div class="media-motion">
                <img class="media" src={item.image} alt={item.title} loading="lazy" />
              </div>
            </div>
          )}
          <div class="card-body">
            <p class="kicker">{item.category}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{item.title}</h3>
            <p class="muted" style="margin-bottom: 8px;">{item.location}</p>
            <p class="muted">{item.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Коротко о студии</h2>
    <div class="stats">
      {studioStats.map((stat) => (
        <div class="stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Услуги в фокусе</h2>
    <div class="grid grid-3">
      {services.map((service) => (
        <article class="surface">
          <p class="kicker">Услуга</p>
          <h3 style="margin-top: 10px; font-size: 1.4rem;">{service.title}</h3>
          <p class="muted">{service.description}</p>
          <ul class="list">
            {service.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div style="display: flex; justify-content: space-between; gap: 20px; align-items: end; flex-wrap: wrap;">
      <div>
        <p class="eyebrow">Блог</p>
        <h2 class="section-title">Последние статьи</h2>
      </div>
      <a class="button-secondary" href="/blog/">Все материалы</a>
    </div>
    <div class="grid grid-visual" style="margin-top: 28px;">
      {blogPosts.map((post) => (
        <BlogCard
          post={post}
          dateFormatter={(date) => `${formatBlogDate(date)} · ${post.data.readingTime}`}
          articleClass="card"
          wrapperClass="media-frame"
          imageClass="media"
          contentClass="card-body"
          metaClass="muted"
          categoryClass="kicker"
          excerptClass="muted"
          linkClass="button-secondary"
          readMoreLabel="Читать статью"
        />
      ))}
    </div>
  </section>
</SiteLayout>

<style is:inline>
  .page-hero h1 {
    font-size: clamp(2.7rem, 7vw, 5.8rem);
  }

  .projects-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(420px, 420px);
    gap: 22px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .projects-strip::-webkit-scrollbar {
    display: none;
  }

  .project-card {
    min-width: 0;
    height: 540px;
    display: grid;
    grid-template-rows: minmax(0, 4fr) minmax(0, 1fr);
  }

  .project-card-link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .project-card-link,
  .project-card-link:hover,
  .project-card-link:visited,
  .project-card-link:active,
  .project-card-link * {
    text-decoration: none;
  }

  .project-card .media-frame {
    height: 100%;
    background: rgba(8, 11, 15, 0.82);
  }

  .project-card .media {
    object-fit: contain;
    object-position: center;
    transform: none;
    padding: 18px;
  }

  .media-frame-static {
    overflow: hidden;
  }

  .project-card .card-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 4px;
    overflow: hidden;
  }

  .project-card .kicker {
    margin: 0;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
  }

  .project-card h3 {
    font-size: 1.16rem !important;
    line-height: 1.1;
    margin-top: 0 !important;
  }

  .project-card .muted {
    font-size: 0.82rem;
    line-height: 1.4;
    margin: 0;
  }

  .project-card .muted[style] {
    margin-bottom: 0 !important;
  }

  .project-card .card-body .muted:last-of-type {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card .media-frame::after,
  .project-card .media-water-layer,
  .project-card .media-water-layer::before,
  .project-card .media-water-layer::after {
    animation: none;
    display: none;
  }

  .projects-caption {
    margin: 20px 0 0;
  }

  .secondary-projects-strip {
    margin-top: 22px;
  }
</style>


