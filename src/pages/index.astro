---

<SiteLayout
  title="INTERIOR.360 | 3D-визуализация интерьеров"
  description="Многостраничный сайт студии INTERIOR.360: портфолио, услуги, блог, информация о студии и контакты."
  canonicalPath="/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow hero-eyebrow">Design & Project Bureau</p>
      <h1>СТУДИЯ ДИЗАЙНА ИНТЕРЬЕРА</h1>
      <div class="button-row">
        <a class="button" href="/services/">Узнать об услугах</a>
        <a class="button-secondary" href="/services/">Рассчитать проект</a>
      </div>
    </div>
    <aside class="hero-panel">
      <p>Почему выбирают нас</p>
      <strong>Показываем проект так, чтобы решение было принять проще</strong>
      <p>Что получает клиент</p>
      <strong>Чёткую подачу, понятный процесс и уверенный результат</strong>
    </aside>
  </section>

  <section class="section">
    <h2 class="section-title">Жилые пространства, аппартаменты</h2>
    <div class="projects-strip">
      {firstStripImages.map((imageName, index) => (
        <article class="card project-card decor-card">
          <div class="media-frame">
            <div class="media-motion">
              <img
                class:list={[
                  "media",
                  imageName === "1.1.jpg" && "media-lifted-150",
                  imageName === "1.2.jpg" && "media-lifted-150-wide",
                  imageName === "1.3.jpg" && "media-lifted-100",
                  imageName === "1.6.jpg" && "media-wide-20",
                  imageName === "1.8.jpg" && "media-lifted-10",
                  imageName === "1.10.jpg" && "media-lifted-100-wide",
                ]}
                src={`/images/channel/${imageName}`}
                alt="Дизайн жилых интерьеров"
                loading={index === 0 ? "eager" : "lazy"}
              />
            </div>
          </div>
          <div class="card-body">
            <p class="kicker">{firstStripContent[imageName]?.kicker ?? "Жилой интерьер"}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{firstStripContent[imageName]?.title ?? "Дизайн интерьера"}</h3>
            <p class="muted">{firstStripContent[imageName]?.description ?? "Подборка визуальных решений для жилого пространства."}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="section-title projects-caption">Таунхаусы дуплексы модульные дома</p>
    <div class="projects-strip secondary-projects-strip">
      {secondStripImages.map((imageName) => (
        <article class="card project-card decor-card">
          <div class="media-frame">
            <div class="media-motion">
              <img
                class:list={[
                  "media",
                  (imageName === "2.3.jpg" || imageName === "2-11.jpg") && "media-lifted-100-wide-left",
                ]}
                src={`/images/channel/${imageName}`}
                alt="Таунхаусы, дуплексы и модульные дома"
                loading="lazy"
              />
            </div>
          </div>
          <div class="card-body">
            <p class="kicker">{secondStripContent[imageName]?.kicker ?? "Жилой интерьер"}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{secondStripContent[imageName]?.title ?? "Таунхаусы и модульные дома"}</h3>
            <p class="muted">{secondStripContent[imageName]?.description ?? "Подборка интерьерных решений для частного жилого пространства."}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="section-title projects-caption">Бренд-пространства, b2b, выставочные стенды, Дизайн шоурумов, pop-up пространства</p>
    <div class="projects-strip secondary-projects-strip">
      {thirdStripImages.map((imageName) => (
        <article class="card project-card decor-card">
          <div class="media-frame">
            <div class="media-motion">
              <img class="media" src={`/images/channel/${imageName}`} alt="Бренд-пространства и шоурумы" loading="lazy" />
            </div>
          </div>
          <div class="card-body">
            <p class="kicker">Коммерческий интерьер</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">Бренд-пространства и шоурумы</h3>
            <p class="muted">Подборка визуальных решений для презентационных и коммерческих пространств.</p>
          </div>
        </article>
      ))}
    </div>
    <p class="section-title projects-caption">Мебель и предметы декора</p>
    <div class="projects-strip secondary-projects-strip">
      {decorImages.map((imageName) => (
        <article class="card project-card decor-card">
          <div class="media-frame">
            <div class="media-motion">
              <img
                class={`media ${imageName === "4.2.jpg" ? "media-lifted" : ""} ${imageName === "4.3.jpg" ? "media-lifted-300" : ""} ${imageName === "4.4.jpg" ? "media-lifted-strong" : ""} ${imageName === "4.5.jpg" ? "media-scaled" : ""} ${imageName === "4.6.jpg" ? "media-lifted-310" : ""} ${imageName === "4.7.jpg" ? "media-lifted-320" : ""} ${imageName === "4.8.jpg" || imageName === "4.10.jpg" ? "media-lifted-50" : ""} ${imageName === "4.9.jpg" ? "media-lifted-50-wide" : ""}`}
                src={`/images/channel/${imageName}`}
                alt="Мебель и предметы декора"
                loading="lazy"
              />
            </div>
          </div>
          <div class="card-body">
            <p class="kicker">{decorCardContent[imageName]?.kicker ?? "Детали интерьера"}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{decorCardContent[imageName]?.title ?? "Мебель и декор"}</h3>
            <p class="muted">{decorCardContent[imageName]?.description ?? "Подборка визуальных акцентов для интерьерной подачи."}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="section-title projects-caption">Средовые и архитектурные концепции</p>
    <div class="projects-strip secondary-projects-strip">
      {conceptImages.map((imageName) => (
        <article class="card project-card decor-card">
          <div class="media-frame">
            <div class="media-motion">
              <img class="media" src={`/images/channel/${imageName}`} alt="Средовые и архитектурные концепции" loading="lazy" />
            </div>
          </div>
          <div class="card-body">
            <p class="kicker">{conceptCardContent[imageName]?.kicker ?? "Архитектурная концепция"}</p>
            <h3 style="margin-top: 10px; font-size: 1.6rem;">{conceptCardContent[imageName]?.title ?? "Концепция"}</h3>
            <p class="muted">{conceptCardContent[imageName]?.description ?? "Концептуальная архитектурная подача."}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Коротко о студии</h2>
    <div class="stats">
      {studioStats.map((stat) => (
        <div class="stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>
</SiteLayout>

<style is:inline>
  .hero-eyebrow {
    text-align: left;
    padding-left: 6px;
  }

  .page-hero .hero-panel {
    display: grid;
    align-content: start;
    gap: 12px;
  }

  .page-hero .hero-panel p {
    margin: 0;
  }

  .page-hero .hero-panel strong {
    line-height: 1.22;
    text-wrap: balance;
  }

  .page-hero .hero-panel p + strong {
    margin-top: -2px;
  }

  .page-hero .hero-panel strong + p {
    margin-top: 8px;
  }

  .page-hero h1 {
    font-size: clamp(2.7rem, 7vw, 5.8rem);
  }

  .projects-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(420px, 420px);
    gap: 22px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .projects-strip::-webkit-scrollbar {
    display: none;
  }

  .project-card {
    min-width: 0;
    height: 540px;
    display: grid;
    grid-template-rows: minmax(0, 4fr) minmax(0, 1fr);
  }

  .project-card-link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .project-card-link,
  .project-card-link:hover,
  .project-card-link:visited,
  .project-card-link:active,
  .project-card-link * {
    text-decoration: none;
  }

  .project-card .media-frame {
    height: 100%;
    background: rgba(8, 11, 15, 0.82);
  }

  .project-card .media {
    object-fit: contain;
    object-position: center;
    transform: none;
    padding: 18px;
  }

  .media-frame-static {
    overflow: hidden;
  }

  .project-card .card-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 4px;
    overflow: hidden;
  }

  .project-card .kicker {
    margin: 0;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
  }

  .project-card h3 {
    font-size: 1.16rem !important;
    line-height: 1.1;
    margin-top: 0 !important;
  }

  .project-card .muted {
    font-size: 0.82rem;
    line-height: 1.4;
    margin: 0;
  }

  .project-card .muted[style] {
    margin-bottom: 0 !important;
  }

  .project-card .card-body .muted:last-of-type {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card .media-frame::after,
  .project-card .media-water-layer,
  .project-card .media-water-layer::before,
  .project-card .media-water-layer::after {
    animation: none;
    display: none;
  }

  .project-card .media.media-lifted {
    padding: 0 !important;
    height: calc(100% + 110px);
    transform: translateY(-110px) !important;
  }

  .project-card .media.media-lifted-strong {
    padding: 0 !important;
    height: calc(100% + 50px);
    transform: translateY(-50px) !important;
  }

  .project-card .media.media-lifted-300 {
    padding: 0 !important;
    height: calc(100% + 185px);
    transform: translateX(-3px) translateY(-185px) scale(1.08) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-310 {
    padding: 0 !important;
    height: calc(100% + 195px);
    transform: translateX(-3px) translateY(-195px) scale(1.08) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-320 {
    padding: 0 !important;
    height: calc(100% + 205px);
    transform: translateX(-3px) translateY(-205px) scale(1.08) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-50 {
    padding: 0 !important;
    height: calc(100% + 70px);
    transform: translateY(-70px) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-50-wide {
    padding: 0 !important;
    height: calc(100% + 120px);
    transform: translateX(-5px) translateY(-120px) scaleX(1.06) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-150 {
    padding: 0 !important;
    height: calc(100% + 100px);
    transform: translateY(-100px) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-150-wide {
    padding: 0 !important;
    width: calc(100% + 23px);
    max-width: none;
    height: calc(100% + 100px);
    transform: translateX(-18px) translateY(-100px) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-100 {
    padding: 0 !important;
    height: calc(100% + 110px);
    transform: translateY(-110px) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-100-wide-left {
    padding: 0 !important;
    width: calc(100% + 20px);
    max-width: none;
    height: calc(100% + 120px);
    transform: translateX(-20px) translateY(-120px) !important;
    transform-origin: center center;
  }

  .project-card .media.media-lifted-100-wide {
    padding: 0 !important;
    width: calc(100% + 20px);
