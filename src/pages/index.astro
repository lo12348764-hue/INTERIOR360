---
import { getCollection } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import { portfolioItems, services, studioStats } from "../data/site";
import SiteLayout from "../layouts/SiteLayout.astro";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
---

<SiteLayout
  title="INTERIOR.360 | 3D-визуализация интерьеров"
  description="Многостраничный сайт студии INTERIOR.360: портфолио, услуги, блог, информация о студии и контакты."
  canonicalPath="/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Interior Visualization Studio</p>
      <h1>СТУДИЯ ДИЗАЙНА ИНТЕРЬЕРА</h1>
      <p class="lead">
        Главная теперь работает как входная страница. Она ведёт в отдельные разделы: портфолио,
        услуги, о студии, блог и контакты. Пользователь быстрее попадает в нужный сценарий,
        а сайт получает понятную структуру маршрутов.
      </p>
      <div class="button-row">
        <a class="button" href="/portfolio/">Смотреть портфолио</a>
        <a class="button-secondary" href="/services/">Узнать об услугах</a>
      </div>
    </div>
    <aside class="hero-panel">
      <p>Структура</p>
      <strong>5 самостоятельных разделов</strong>
      <p>Подходит для</p>
      <strong>SEO, рекламы и удобной навигации</strong>
    </aside>
  </section>

  <section class="section">
    <h2 class="section-title">Основные разделы</h2>
    <p class="section-copy">
      Вместо якорной навигации на одной странице теперь есть отдельные URL для ключевых направлений сайта.
    </p>
    <div class="grid grid-3">
      <article class="card">
        <img class="media" src={portfolioItems[0].image} alt="Пример интерьерной визуализации" loading="eager" />
        <div class="card-body">
          <p class="kicker">Портфолио</p>
          <h3 style="margin-top: 10px; font-size: 1.6rem;">Подборка проектов</h3>
          <p class="muted">
            Кейсы по жилым, коммерческим и девелоперским объектам с описанием задач и результата.
          </p>
          <a class="button-secondary" href="/portfolio/">Открыть раздел</a>
        </div>
      </article>
      <article class="card">
        <img
          class="media"
          src="/images/channel/living-dark.jpg"
          alt="Рабочий процесс команды"
        />
        <div class="card-body">
          <p class="kicker">Услуги</p>
          <h3 style="margin-top: 10px; font-size: 1.6rem;">Чёткие пакеты работ</h3>
          <p class="muted">
            Отдельная страница с форматами сотрудничества, этапами производства и логикой работы.
          </p>
          <a class="button-secondary" href="/services/">Открыть раздел</a>
        </div>
      </article>
      <article class="card">
        <img
          class="media"
          src="/images/channel/house-exterior.jpg"
          alt="Студия и блог"
        />
        <div class="card-body">
          <p class="kicker">Контекст</p>
          <h3 style="margin-top: 10px; font-size: 1.6rem;">О студии, блог и контакты</h3>
          <p class="muted">
            Смысловые разделы вынесены отдельно, поэтому сайт стал ближе к полноценному корпоративному формату.
          </p>
          <div class="button-row">
            <a class="button-secondary" href="/about/">О студии</a>
            <a class="button-secondary" href="/blog/">Блог</a>
            <a class="button-secondary" href="/contact/">Контакты</a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Коротко о студии</h2>
    <div class="stats">
      {studioStats.map((stat) => (
        <div class="stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Услуги в фокусе</h2>
    <div class="grid grid-3">
      {services.map((service) => (
        <article class="surface">
          <p class="kicker">Услуга</p>
          <h3 style="margin-top: 10px; font-size: 1.4rem;">{service.title}</h3>
          <p class="muted">{service.description}</p>
          <ul class="list">
            {service.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div style="display: flex; justify-content: space-between; gap: 20px; align-items: end; flex-wrap: wrap;">
      <div>
        <p class="eyebrow">Блог</p>
        <h2 class="section-title">Последние статьи</h2>
      </div>
      <a class="button-secondary" href="/blog/">Все материалы</a>
    </div>
    <div class="grid grid-3" style="margin-top: 28px;">
      {blogPosts.map((post) => (
        <BlogCard
          post={post}
          dateFormatter={(date) => `${formatBlogDate(date)} · ${post.data.readingTime}`}
          articleClass="card"
          imageClass="media"
          contentClass="card-body"
          metaClass="muted"
          categoryClass="kicker"
          excerptClass="muted"
          linkClass="button-secondary"
          readMoreLabel="Читать статью"
        />
      ))}
    </div>
  </section>
</SiteLayout>


