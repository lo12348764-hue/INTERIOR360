---
import { getCollection } from "astro:content";
import BlogCard from "../../components/BlogCard.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
---

<SiteLayout
  title="Блог | INTERIOR.360"
  description="Блог студии INTERIOR.360 о 3D-визуализации, интерьерах и рабочем процессе."
  canonicalPath="/blog/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Блог</p>
      <h1>Блог студии</h1>
      <p class="lead">
        Блог теперь живёт как самостоятельный раздел. Это уже не фрагмент лендинга, а отдельная контентная зона,
        которую можно развивать для SEO и экспертной коммуникации.
      </p>
    </div>
    <button class="hero-panel brief-panel-trigger" type="button" data-brief-open aria-haspopup="dialog" aria-controls="project-brief-modal">
      <strong>Заполнить бриф проекта</strong>
    </button>
  </section>

  <section class="blog-grid">
    {posts.map((post) => (
      <BlogCard
        post={post}
        dateFormatter={(date) => `${formatBlogDate(date)} · ${post.data.readingTime}`}
        articleClass="card"
        wrapperClass="media-frame"
        imageClass="media"
        contentClass="card-body"
        metaClass="muted"
        categoryClass="kicker"
        excerptClass="muted"
        linkClass="button-secondary"
        readMoreLabel="Читать статью"
      />
    ))}
  </section>

  <style>
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .blog-grid :global(.card) {
      height: auto;
      display: grid;
      grid-template-rows: 200px auto;
    }

    .blog-grid :global(.media-frame) {
      aspect-ratio: auto;
    }

    .blog-grid :global(.media) {
      height: 200px;
    }

    .blog-grid :global(.card-body) {
      padding: 20px;
    }

    .blog-grid :global(h3) {
      font-size: 1.2rem !important;
      margin: 10px 0 !important;
      line-height: 1.3;
    }

    .blog-grid :global(.muted) {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .blog-grid :global(.button-secondary) {
      margin-top: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 18px;
      border-radius: 999px;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.7rem;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.03);
      color: var(--text);
      transition: border-color 0.2s ease;
    }

    .blog-grid :global(.button-secondary:hover) {
      border-color: var(--accent);
    }

    @media (max-width: 740px) {
      .blog-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</SiteLayout>
