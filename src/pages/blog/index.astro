---
import { getCollection } from "astro:content";
import BlogCard from "../../components/BlogCard.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
---

<SiteLayout
  title="Блог | INTERIOR.360"
  description="Блог студии INTERIOR.360 о 3D-визуализации, интерьерах и рабочем процессе."
  canonicalPath="/blog/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Блог</p>
      <h1>Блог студии</h1>
      <p class="lead">
        Блог теперь живёт как самостоятельный раздел. Это уже не фрагмент лендинга, а отдельная контентная зона,
        которую можно развивать для SEO и экспертной коммуникации.
      </p>
    </div>
    <aside class="hero-panel">
      <p>Материалов</p>
      <strong>{posts.length}</strong>
      <p>Формат</p>
      <strong>Полноценные страницы статей</strong>
    </aside>
  </section>

  <section class="grid grid-3">
    {posts.map((post) => (
      <BlogCard
        post={post}
        dateFormatter={(date) => `${formatBlogDate(date)} · ${post.data.readingTime}`}
        articleClass="card"
        imageClass="media"
        contentClass="card-body"
        metaClass="muted"
        categoryClass="kicker"
        excerptClass="muted"
        linkClass="button-secondary"
        readMoreLabel="Читать статью"
      />
    ))}
  </section>
</SiteLayout>
