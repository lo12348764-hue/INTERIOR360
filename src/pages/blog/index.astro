---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);

const formatDayOfWeek = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", { weekday: "long" }).format(date);
---

<SiteLayout
  title="Блог | INTERIOR.360"
  description="Блог студии INTERIOR.360 о 3D-визуализации, интерьерах и рабочем процессе."
  canonicalPath="/blog/"
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">Блог</p>
      <h1>Блог студии</h1>
      <p class="lead">
        Полезные статьи о дизайне интерьера, 3D-визуализации и процессе работы над проектами.
      </p>
    </div>
    <button class="hero-panel brief-panel-trigger" type="button" data-brief-open aria-haspopup="dialog" aria-controls="project-brief-modal">
      <strong>Заполнить бриф проекта</strong>
    </button>
  </section>

  <section class="blog-list">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}/`} class="blog-list-item">
        <div class="blog-list-date">
          <span class="blog-list-day">{formatDayOfWeek(post.data.date)}</span>
          <span class="blog-list-full">{formatBlogDate(post.data.date)}</span>
        </div>
        <div class="blog-list-content">
          <h2 class="blog-list-title">{post.data.title}</h2>
          <p class="blog-list-excerpt">{post.data.excerpt}</p>
        </div>
      </a>
    ))}
  </section>
</SiteLayout>

<style>
  .blog-list {
    display: grid;
    gap: 0;
  }

  .blog-list-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease;
  }

  .blog-list-item:first-child {
    border-top: 1px solid var(--border);
  }

  .blog-list-item:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .blog-list-date {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
  }

  .blog-list-day {
    font-size: 0.82rem;
    color: var(--muted);
    text-transform: capitalize;
  }

  .blog-list-full {
    font-size: 0.9rem;
    color: var(--text);
  }

  .blog-list-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .blog-list-title {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .blog-list-item:hover .blog-list-title {
    color: var(--accent);
  }

  .blog-list-excerpt {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 740px) {
    .blog-list-item {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 18px 0;
    }

    .blog-list-date {
      flex-direction: row;
      gap: 8px;
      align-items: center;
    }

    .blog-list-title {
      font-size: 1.2rem;
    }

    .blog-list-excerpt {
      font-size: 0.9rem;
    }
  }
</style>
