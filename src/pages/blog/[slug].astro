---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
---

<SiteLayout
  title={`${post.data.title} | INTERIOR.360`}
  description={post.data.description}
  canonicalPath={`/blog/${post.slug}/`}
>
  <section class="page-hero">
    <div>
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.excerpt}</p>
      <p class="muted" style="text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.78rem;">
        {formatBlogDate(post.data.date)} · {post.data.readingTime} · {post.data.author}
      </p>
    </div>
    <aside class="hero-panel">
      <p>Раздел</p>
      <strong>Блог INTERIOR.360</strong>
      <p>Назад</p>
      <strong><a href="/blog/" style="text-decoration: none;">Ко всем статьям</a></strong>
    </aside>
  </section>

  <img
    src={post.data.cover}
    alt={post.data.coverAlt ?? post.data.title}
    class="media"
    style="height: min(62vw, 560px); border-radius: 28px; border: 1px solid var(--border); margin-bottom: 32px;"
  />

  <article class="surface article-content">
    <Content />
  </article>

  <div class="surface" style="margin-top: 24px;">
    <p class="kicker">Следующий шаг</p>
    <h2 style="margin-top: 10px; font-size: 2rem;">Нужна визуализация под ваш проект?</h2>
    <p class="muted">
      В отдельном разделе контактов собрали каналы связи и список материалов, которые помогут быстро стартовать.
    </p>
    <a class="button" href="/contact/">Перейти в контакты</a>
  </div>
</SiteLayout>

<style is:global is:inline>
  .article-content :global(h2) {
    margin: 34px 0 16px;
    font-size: 1.9rem;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--muted);
    line-height: 1.85;
    font-size: 1.05rem;
  }

  .article-content :global(ul) {
    padding-left: 18px;
  }
</style>
